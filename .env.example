# Server (copy to .env and adjust)
PORT=5000

# SQLite database file (optional)
# SQLITE_PATH=./data/star-purpose.db

# Bootstrap admin if this email is not yet registered (optional overrides)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin

# Frontend: Vite dev proxy or explicit API origin
# VITE_API_URL=http://localhost:5000
